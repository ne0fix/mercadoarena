#### 5.1.5 ViewModel para Courts Admin

**Arquivo novo:** `src/viewmodels/admin/useCourtsAdminViewModel.ts`

```ts
export function useCourtsAdminViewModel() {
  const queryClient = useQueryClient()

  const { data: courts, isLoading } = useQuery({
    queryKey: ['admin-courts'],
    queryFn: () => fetch('/api/admin/courts').then(r => r.json()),
  })

  const createMutation = useMutation({
    mutationFn: (data: CreateCourtInput) =>
      fetch('/api/admin/courts', { method: 'POST', body: JSON.stringify(data) }).then(r => r.json()),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['admin-courts'] }),
  })

  const updateMutation = useMutation({ ... })
  const deleteMutation = useMutation({ ... })

  return { courts, isLoading, createMutation, updateMutation, deleteMutation }
}
```

**Critério de Aceitação:**
- Admin consegue criar nova quadra via formulário
- Admin consegue editar todos os campos de uma quadra
- Admin consegue desativar quadra (com proteção de reservas futuras)
- Lista atualiza sem recarregar a página

